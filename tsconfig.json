{
    "extends": [
        "@tsconfig/node24/tsconfig.json",
        "@tsconfig/node-ts/tsconfig.json"
    ],
    "compilerOptions": {
        "alwaysStrict": true,          /* Ensures 'use strict' is emitted in all JS files */
        "lib": ["ESNext", "DOM"],
        "types": ["hypenation"],
        "typeRoots": [
            "./node_modules/@types",
            "./src/types"
        ],

        "module": "NodeNext",
        "moduleResolution": "NodeNext"
    },
    "include": [
        "src/**/*.ts"
    ],
    "references": [
        { "path": "./docs/.vitepress" },
        { "path": "./test" }
    ]
}