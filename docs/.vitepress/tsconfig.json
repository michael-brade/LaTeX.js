{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,

        "isolatedModules": true,
        "skipLibCheck": true,
        "emitDeclarationOnly": true
    },
    "include": [
        "vite-env.d.ts",
        "config.ts",
